GROQ_API_KEY=
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_ENABLED=true
LLM_PARSER_FALLBACK_ENABLED=false
APP_ENV=development
LOG_LEVEL=INFO

# Phase 5C.4A API deployment boundary. Development-safe placeholders only.
SECURITY_HEADERS_ENABLED=true
TRUSTED_HOSTS=["localhost","127.0.0.1"]
CORS_ALLOWED_ORIGINS=[]
CORS_ALLOW_CREDENTIALS=false
FORWARDED_HEADERS_ENABLED=false
TRUSTED_PROXY_IPS=[]
HTTPS_REQUIRED=false
API_DOCS_ENABLED=true
MAX_REQUEST_BODY_BYTES=54525952
MAX_UPLOAD_BYTES=52428800
HSTS_MAX_AGE_SECONDS=86400

# Phase 5C.4B transient rate limiting. The memory backend is development-only.
# Production must use Redis, enable protection, fail closed, and replace the
# key secret placeholder with an independently generated secret of 32+ bytes.
RATE_LIMITING_ENABLED=true
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REDIS_URL=redis://localhost:6379/1
RATE_LIMIT_KEY_SECRET=replace-with-at-least-32-random-characters
RATE_LIMIT_GENERAL_REQUESTS=120
RATE_LIMIT_GENERAL_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_FAILURES=10
RATE_LIMIT_AUTH_FAILURE_WINDOW_SECONDS=60
RATE_LIMIT_JOB_SUBMISSIONS=5
RATE_LIMIT_JOB_SUBMISSION_WINDOW_SECONDS=60
RATE_LIMIT_MUTATIONS=30
RATE_LIMIT_MUTATION_WINDOW_SECONDS=60
RATE_LIMIT_READS=120
RATE_LIMIT_READ_WINDOW_SECONDS=60
RATE_LIMIT_PREFIX=soc-rate-limit
RATE_LIMIT_FAIL_CLOSED=true

# Phase 5D.1 structured metadata search. Production must replace this cursor
# secret with an independently generated secret of at least 32 bytes.
SEARCH_CURSOR_SECRET=replace-with-at-least-32-random-characters
SEARCH_DEFAULT_PAGE_SIZE=50
SEARCH_MAX_PAGE_SIZE=200

# Phase 5D.2A retention planning. The CLI is dry-run only; these values do not
# enable deletion or archival.
RETENTION_POLICY_VERSION=v1
RETENTION_CANONICAL_EVENT_DAYS=30
RETENTION_DETECTION_SIGNAL_DAYS=90
RETENTION_COMPLETED_JOB_DAYS=90
RETENTION_TERMINAL_INCIDENT_DAYS=365
RETENTION_AUDIT_EVENT_DAYS=365

# Phase 5D.2B non-destructive operational archives. Keep this root separate
# from STAGING_DIR. Local archives are integrity protected but not encrypted.
RETENTION_ARCHIVE_BACKEND=local
RETENTION_ARCHIVE_ROOT=./var/retention-archives
RETENTION_ARCHIVE_BATCH_SIZE=1000
RETENTION_ARCHIVE_SCHEMA_VERSION=retention-archive/v1
RETENTION_CLEANUP_BATCH_SIZE=500
RETENTION_CLEANUP_LEASE_SECONDS=300

# API authorization: disabled bypasses authentication and RBAC for local
# development and tests only, using an explicit local-development admin.
# Set to api_key for database-backed Bearer authentication.
AUTH_MODE=disabled

# External OIDC/JWT resource-server settings. Safe placeholders only.
# Issuer and audience are required when AUTH_MODE=oidc or hybrid.
OIDC_ISSUER=https://identity.example.test/tenant
OIDC_AUDIENCE=soc-api
OIDC_DISCOVERY_URL=https://identity.example.test/tenant/.well-known/openid-configuration
OIDC_ALLOWED_ALGORITHMS=["RS256"]
OIDC_CLOCK_SKEW_SECONDS=30
OIDC_HTTP_TIMEOUT_SECONDS=5
OIDC_METADATA_CACHE_TTL_SECONDS=300
OIDC_JWKS_CACHE_TTL_SECONDS=300
OIDC_TOKEN_USE_CLAIM=token_use
OIDC_ACCESS_TOKEN_USE_VALUE=access
OIDC_REQUIRE_ACCESS_TOKEN_INDICATOR=true
OIDC_ROLES_CLAIM=roles
OIDC_ROLE_MAPPING={"soc-viewer":"viewer","soc-analyst":"analyst","soc-service":"service","soc-admin":"admin"}
OIDC_DISPLAY_NAME_CLAIM=preferred_username
OIDC_REQUIRE_HTTPS=true

# Phase 4 Triage Settings
MAX_AGENT_ITERATIONS=5
MAX_SEARCH_CALLS=3
MAX_SEARCH_RESULTS=10
TRIAGE_TIMEOUT_SECONDS=120
TRIAGE_CACHE_ENABLED=true
